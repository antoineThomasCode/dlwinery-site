    <div id="ageVerification">
        <div>
            <figure>
                <img src="https://shop.dlwinery.com/wp-content/uploads/2023/01/leseurre-logo.svg" alt="Logo Of Domaine LeSeurre Winery">
            </figure>
            <h2>Age Verification</h2>
            <p>Are you over 21 years of age ?</p>
            <div class="btns-container">
                <button id="exitBtn" class="borderedBtn">No</button>
                <button id="enterBtn" class="borderedBtn">Yes</button>
            </div>
