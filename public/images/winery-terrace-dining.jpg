    <div id="newsletterModal">
        <div>
            <button id="closeBtn" aria-label="Close">
                <i class="ph ph-x"></i>
            </button>
            <h2>Stay in the loop !</h2>
            <p>Join our email list to stay up to date on new releases, upcoming events, important updates, promotions, and more.</p>
                <form id="newsLetterForm">
        <input type="email" name="email" placeholder="Email address" required>
        <input type="hidden" name="nonce" value="15c0b7bf2b">
        <button type="submit">Join now</button>
        <div id="formResponse"></div>
    </form>

    <script>
        document.getElementById('newsLetterForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const form = e.target;
            const email = form.email.value.trim();
            const nonce = form.nonce.value;
            const responseBox = document.getElementById('formResponse');
            const submitButton = form.querySelector('button');

            // Expression régulière basique pour validation email
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            // Vérification email
            if (!emailRegex.test(email)) {
                responseBox.innerText = 'Please enter a valid email address.';
                return;
            }

            // Désactiver le bouton pour éviter les clics multiples
            submitButton.disabled = true;
            responseBox.innerText = 'Submitting...';

            try {
                const res = await fetch('https://shop.dlwinery.com/wp-admin/admin-post.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({
                        action: 'ajax_square_form',
                        email: email,
                        nonce: nonce
                    })
                });

                const text = await res.text();
                responseBox.innerText = text;
            } catch (err) {
                responseBox.innerText = 'An unexpected error occurred.';
            }

            submitButton.disabled = false;
        });
    </script>
            </div>
    </div>
